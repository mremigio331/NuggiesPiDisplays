{
  "active_display": "stocks",
  "auto_start_display": true,
  "log_level": "INFO",

  "stocks": {
    "stock_abbrs": ["AAPL", "MSFT"],
    "stock_cycles": [
      { "key": "intraday", "period": "1d",  "interval": "5m", "label": "Today",        "enabled": true },
      { "key": "6month",   "period": "6mo", "interval": "1d", "label": "6 Months",     "enabled": true },
      { "key": "ytd",      "period": "ytd", "interval": "1d", "label": "Year to Date", "enabled": true },
      { "key": "1year",    "period": "1y",  "interval": "1d", "label": "1 Year",       "enabled": true }
    ],
    "interval_seconds": 60,
    "display_brightness": 80,
    "market_hours_only": false,
    "timezone": "America/Los_Angeles"
  },

  "mta": {
    "station": "111 St - 194",
    "cycle": true,
    "cycle_time": "300",
    "force_change_station": "",
    "log_level": "INFO",
    "create_log_file": false,
    "log_file_name": "logs/mta.log",
    "log_error_file_name": "logs/mta_errors.log"
  },

  "clock": {
    "timezone": "America/New_York",
    "color": [255, 255, 255],
    "use_24h": false
  },

  "weather": {
    "latitude": null,
    "longitude": null,
    "city_label": "",
    "use_ip_location": true,
    "units": "fahrenheit",
    "cycle_duration": 60
  }
}
